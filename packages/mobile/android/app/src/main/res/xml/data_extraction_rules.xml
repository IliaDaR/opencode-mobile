<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
        <exclude domain="file" path=".opencode-memory/"/>
        <exclude domain="file" path="opencode-snapshots/"/>
        <exclude domain="file" path="opencode-profile.json"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="FlutterSecureStorage"/>
        <exclude domain="file" path=".opencode-memory/"/>
        <exclude domain="file" path="opencode-snapshots/"/>
        <exclude domain="file" path="opencode-profile.json"/>
    </device-transfer>
</data-extraction-rules>
